# Initialize a new Expo app using Bun

bun create expo-app frontend-app --template tabs

# Change directory

cd frontend-app

# Install native routing, authentication state, validation, & HTTP utilities

bun add zustand axios zod expo-secure-store
bunx expo start

# Install drawer

bun add @react-navigation/native
bun add react-native-screens react-native-safe-area-context

bun add lucide-react-native react-native-svg

bun add moti
bunx expo install react-native-reanimated

<!-- Whatsapp linking -->

bunx expo install expo-linking
bunx expo install expo-build-properties

<!-- payment integration -->

bunx expo install react-native-webview

# app.config.js

plugins: [
[
"expo-build-properties",
{
android: {
// Manifest queries injection for explicit package visibility validation
manifestQueries: {
packageNames: ["com.whatsapp"],
intentQueries: [
{
action: "android.intent.action.VIEW",
data: { scheme: "whatsapp" }
}
]
}
}
}
]
]

# update expo sdk

bun add expo@56.0.6
bunx expo install --check

bun add -g eas-cli
eas login
eas build:configure

eas project:info

# Setup development client (dev client)

bunx expo install expo-dev-client

For Android:
eas build --platform android --profile development
eas build --platform android --profile preview
For iOS:
eas build --platform ios --profile development

# For Android Device

eas build --profile development --platform android

eas build:run -p android
bunx expo start --dev-client

# For iOS Device

eas device:register
eas build --profile development --platform ios

# OR if you generate builds using Expo Application Services (EAS):

eas build --profile development --platform all

You only need to run eas build --profile development again if you:
Install a new library that contains native code.
Modify native configuration files (e.g., adding permissions in app.json or changing native project settings). Upgrade your Expo SDK version.
If you only change your React/JavaScript logic, you never need to rebuild!

bunx expo start --dev-client

