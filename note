# Initialize a new Expo app using Bun

bun create expo-app frontend-app --template tabs

# Change directory

cd frontend-app

# Install native routing, authentication state, validation, & HTTP utilities

bun add zustand axios zod expo-secure-store
bunx expo start

# Install drawer

bun add @react-navigation/native
bun add react-native-screens react-native-safe-area-context

# update expo sdk

bun add expo@56.0.6
bunx expo install --check
